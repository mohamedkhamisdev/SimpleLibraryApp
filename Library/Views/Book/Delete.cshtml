@model Book
@{
    ViewData["Title"] = "Delete Book";
}

<form method="post" asp-action="Delete">
    <div class="border p-3 mb-2 mt-2">
        <div class="row pb-2">
            <h2 class="text-primary">@ViewData["Title"]</h2>
        </div>
    </div>

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" disabled class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Author" class="form-label"></label>
        <input asp-for="Author" disabled class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ISBN" class="form-label"></label>
        <input asp-for="ISBN" disabled class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" disabled class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Category</label>
        <input asp-for="Category.Name" disabled class="form-control" value="@Model.Category?.Name" />
    </div>

    <hr />
    <br />

    <div>
        <button type="submit" class="btn btn-danger" style="width:150px">Delete</button>
        <a asp-action="Index" class="btn btn-dark">Back to List</a>
    </div>
</form>