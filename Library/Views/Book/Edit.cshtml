@model Book
@{
    ViewData["Title"] = "Edit Book";
}

<form method="post">
    <div class="border p-3 mb-2 mt-2">
        <div class="row pb-2">
            <h2 class="text-primary">@ViewData["Title"]</h2>
        </div>
    </div>

    <!-- إظهار أخطاء النموذج فقط (وليس كل حقل على حدة) -->
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- حقل Id مخفي لتحديد الكتاب عند الإرسال -->
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Author" class="form-label"></label>
        <input asp-for="Author" class="form-control" />
        <span asp-validation-for="Author" class="text-danger"></span>
    </div>

    <!-- إضافة حقل ISBN (ضروري بعد إضافته للنموذج) -->
    <div class="mb-3">
        <label asp-for="ISBN" class="form-label"></label>
        <input asp-for="ISBN" class="form-control" placeholder="e.g., 978-3-16-148410-0" />
        <span asp-validation-for="ISBN" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <!-- استخدام textarea بدلاً من input للنصوص الطويلة -->
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <!-- إزالة disabled للسماح بتغيير التصنيف (إذا كان ذلك مطلوباً) -->
        <select asp-for="CategoryId" asp-items="@ViewBag.CategoryList" class="form-control">
            <option value="">-- Select Category --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- لا نعرض CreatedDate لأنه يتم تعيينه تلقائياً -->

    <hr />
    <br />

    <div>
        <button type="submit" class="btn btn-primary" style="width:150px">Save</button>
        <!-- استخدام رابط بدلاً من زر للعودة إلى القائمة -->
        <a asp-action="Index" class="btn btn-dark">Back to List</a>
    </div>
</form>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
      
        select.form-control {
            background-color: transparent !important;
            color: #ffffff !important;
            border: 1px solid #ffffff; 
        }

            select.form-control option {
                background-color: #333333; 
                color: #ffffff;
            }
    </style>
}